# ============================================================================
# ScholarAssist — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# For local development with Docker Compose, the defaults below will work.
# ============================================================================

# General
SCHOLARASSIST_ENV=development

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# Spark
SPARK_MASTER_URL=spark://localhost:7077

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_SECRET_KEY=dev-secret-key-change-in-production
API_DEBUG=true

# Provider API Keys (obtain from each provider)
PROVIDER_OPENALEX_EMAIL=your-email@example.com
PROVIDER_CROSSREF_EMAIL=your-email@example.com
# PROVIDER_SEMANTIC_SCHOLAR_API_KEY=
# PROVIDER_CORE_API_KEY=
# PROVIDER_CROSSREF_PLUS_TOKEN=
